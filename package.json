{
  "name": "@ambystech/ambykit",
  "version": "0.1.1",
  "description": "Spec-Driven Development framework that helps AI coding assistants build better software — author your specs, user stories, UI design, plans and tasks once, and emit native config for Claude Code, OpenCode, GitHub Copilot, Cursor, Antigravity and more.",
  "keywords": [
    "spec-driven-development",
    "sdd",
    "ai",
    "coding-assistant",
    "claude-code",
    "opencode",
    "copilot",
    "cursor",
    "antigravity",
    "agents.md"
  ],
  "license": "MIT",
  "author": "ambystech",
  "publisher": "Ambystech",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ambystechcom/AmbyKit.git"
  },
  "homepage": "https://ambystech.io/AmbyKit",
  "bugs": {
    "url": "https://github.com/ambystechcom/AmbyKit/issues"
  },
  "type": "module",
  "bin": {
    "ambykit": "dist/cli/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "src/templates",
    "src/prompts",
    "src/reference",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "@types/node": "^20.14.0"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "zod": "^3.23.0"
  },
  "allowScripts": {
    "esbuild@0.21.5": true
  }
}
